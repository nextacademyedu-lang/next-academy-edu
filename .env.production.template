# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=nextacademy
DB_PASSWORD=<strong-password>
DB_NAME=nextacademy
# Production: use Neon pooler URL (ends in -pooler.neon.tech) for better connection handling
# Development: direct connection URL is fine
DATABASE_URI=postgresql://nextacademy:<strong-password>@postgres:5432/nextacademy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<strong-redis-password>
REDIS_URL=redis://:<strong-redis-password>@redis:6379/0

# ── Payload CMS ───────────────────────────────────────────────────────────────
PAYLOAD_SECRET=<crypto-random-32-chars>
PAYLOAD_ADMIN_EMAIL=admin@nextacademyedu.com
PAYLOAD_ADMIN_PASSWORD=<strong-admin-password>
PAYLOAD_ADMIN_SYNC_PASSWORD=false

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nextacademyedu.com
NEXT_PUBLIC_SERVER_URL=https://nextacademyedu.com
NODE_ENV=production

# ── Paymob ────────────────────────────────────────────────────────────────────
ENABLE_PAYMOB=true
PAYMOB_API_KEY=egy_sk_live_...
PAYMOB_PUBLIC_KEY=egy_pk_live_...
PAYMOB_INTEGRATION_ID=<live-card-id>
PAYMOB_WALLET_INTEGRATION_ID=<live-wallet-id>
PAYMOB_IFRAME_ID=<optional-iframe-id>
PAYMOB_HMAC_SECRET=<live-hmac-secret>

# ── EasyKash ──────────────────────────────────────────────────────────────────
EASYKASH_API_TOKEN=<live-token>
EASYKASH_HMAC_SECRET=<live-secret>

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_live_...
RESEND_FROM_EMAIL=noreply@nextacademyedu.com
RESEND_FROM_NAME=Next Academy

# ── Media Storage (Recommended for production) ───────────────────────────────
# If set, Payload uploads go to S3/R2 and survive every deploy.
S3_BUCKET=<bucket-name>
S3_REGION=auto
S3_ACCESS_KEY=<access-key-id>
S3_SECRET_KEY=<secret-access-key>
S3_ENDPOINT=<https://s3-compatible-endpoint>
S3_MEDIA_PREFIX=nextacademy/media
# Set true for providers like MinIO / some R2 setups
S3_FORCE_PATH_STYLE=false
# Optional: CDN/custom public domain for media (used by Next Image allow-list)
S3_PUBLIC_BASE_URL=<https://cdn.nextacademyedu.com>
# Local fallback (used only when S3_* is not configured)
PAYLOAD_UPLOAD_DIR=/app/media
PAYLOAD_MEDIA_BASE_URL=/media

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<client-id>
GOOGLE_CLIENT_SECRET=<client-secret>

# ── Twenty CRM ────────────────────────────────────────────────────────────────
TWENTY_CRM_URL=https://crm.nextacademyedu.com
TWENTY_CRM_API_KEY=<twenty-api-key>
TWENTY_APP_SECRET=<openssl-rand-base64-32>
TWENTY_SERVER_URL=https://crm.nextacademyedu.com
TWENTY_TAG=latest
CRM_SYNC_BATCH_SIZE=25
CRM_SYNC_MAX_ATTEMPTS=5
CRM_SYNC_STALE_LOCK_MINUTES=30
# Optional if your Twenty workspace uses custom object names:
TWENTY_RESOURCE_CONTACTS=people
TWENTY_RESOURCE_COMPANIES=companies
TWENTY_RESOURCE_LEADS=leads
TWENTY_RESOURCE_DEALS=opportunities

# ── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=<crypto-random-32-chars>
