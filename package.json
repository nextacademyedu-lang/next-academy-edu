{
  "name": "nextacademy-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "payload generate:importmap && next build",
    "check:env": "node scripts/check-coolify-env.mjs",
    "generate:importmap": "payload generate:importmap",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:admin": "node --env-file=.env --env-file=.env.local --import tsx scripts/seed-admin.ts",
    "seed:dev": "node --env-file=.env --env-file=.env.local --import tsx scripts/seed-dev.ts",
    "crm:backfill": "node --env-file=.env --env-file=.env.local --import tsx scripts/backfill-crm-sync.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.79.0",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/storage-s3": "3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "@react-email/components": "^1.0.10",
    "date-fns-tz": "^3.2.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.35.0",
    "googleapis": "^171.4.0",
    "graphql": "^16.13.1",
    "gsap": "^3.14.2",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "next": "15.4.11",
    "next-intl": "^4.8.3",
    "payload": "^3.79.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-email": "^5.2.10",
    "resend": "^6.9.3",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "sass": "^1.89.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.2"
  }
}
